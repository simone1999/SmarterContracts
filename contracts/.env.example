# Deployer private key (no 0x prefix)
PRIVATE_KEY=

# Target EVM network
RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
CHAIN_ID=1                          # optional — auto-detected from RPC if omitted

# Block explorer (optional — only needed for contract verification)
EXPLORER_API_KEY=
EXPLORER_API_URL=https://api.etherscan.io/api
EXPLORER_BROWSER_URL=https://etherscan.io

# Common block explorer examples:
#
#   Ethereum mainnet
#     EXPLORER_API_URL=https://api.etherscan.io/api
#     EXPLORER_BROWSER_URL=https://etherscan.io
#
#   Sepolia
#     EXPLORER_API_URL=https://api-sepolia.etherscan.io/api
#     EXPLORER_BROWSER_URL=https://sepolia.etherscan.io
#
#   Base
#     EXPLORER_API_URL=https://api.basescan.org/api
#     EXPLORER_BROWSER_URL=https://basescan.org
#
#   Arbitrum One
#     EXPLORER_API_URL=https://api.arbiscan.io/api
#     EXPLORER_BROWSER_URL=https://arbiscan.io
#
#   Polygon
#     EXPLORER_API_URL=https://api.polygonscan.com/api
#     EXPLORER_BROWSER_URL=https://polygonscan.com

# --- Set after running deployRegistry.ts, used by deployPeriodicCounter.ts ---
REGISTRY_ADDRESS=
